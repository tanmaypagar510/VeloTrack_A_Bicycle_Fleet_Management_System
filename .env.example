# ──── VeloTrack Docker Compose Environment ────
# Copy this file to .env and fill in the values

# PostgreSQL
POSTGRES_USER=velotrack
POSTGRES_PASSWORD=velotrack_secret
POSTGRES_DB=velotrack

# Database Connection
DATABASE_URL=postgresql://velotrack:velotrack_secret@postgres:5432/velotrack

# JWT Configuration
JWT_SECRET=supersecretjwtkey123changeinproduction
JWT_EXPIRY_HOURS=24

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Service URLs (internal Docker network)
BICYCLE_SERVICE_URL=http://bicycle-service:5002
MAINTENANCE_RENTAL_SERVICE_URL=http://maintenance-rental-service:5003
MAINTENANCE_ASSISTANT_SERVICE_URL=http://maintenance-assistant-service:5004

# Ollama LLM
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=mistral

